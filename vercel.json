{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://f41b6c04b59c7d52-217-76-48-32.serveousercontent.com/api/:path*"
    },
    {
      "source": "/webhook/:path*",
      "destination": "https://f41b6c04b59c7d52-217-76-48-32.serveousercontent.com/webhook/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://lumix-studio.vercel.app"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, Cookie"
        }
      ]
    }
  ]
}