{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://choco.de5.net/api/:path*"
    },
    {
      "source": "/trpc/:path*",
      "destination": "https://choco.de5.net/trpc/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
