{
  "name": "tts-srt-generator",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "imports": {
    "@shared/*": "./dist/shared/*.ts"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch backend/_core/index.ts",
    "build": "vite build && cp -r frontend/dist/* dist/public/ && esbuild backend/_core/index.ts --platform=node --bundle --format=cjs --outfile=dist/index.cjs --external:dotenv --external:fs --external:path --external:os --external:crypto --external:fs/promises --alias:@shared/const=./dist/shared/const.ts --alias:@shared/types=./dist/shared/types.ts --alias:@shared/_core/errors=./dist/shared/_core/errors.ts && cp -r shared dist/",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate:mysql && drizzle-kit push:mysql",
    "reset-db": "tsx backend/reset-db.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "add": "^2.0.6",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.18.1",
    "esbuild": "^0.25.0",
    "pnpm": "^10.15.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-manus-runtime": "^0.0.57",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide"
    ]
  }
}
