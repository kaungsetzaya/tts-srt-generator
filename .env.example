# ═══════════════════════════════════════════════════════════
#  LUMIX STUDIO — Environment Variables
#  Copy these into your .env file and fill in the blanks
# ═══════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000
BASE_URL=https://your-domain.com
SITE_URL=https://your-domain.com
PUBLIC_DOWNLOAD_URL=https://your-domain.com

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=mysql://USERNAME:PASSWORD@HOST:3306/DATABASE_NAME

# ─── Security ─────────────────────────────────────────────
JWT_SECRET=
DOWNLOAD_SECRET=

# ─── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_TELEGRAM_ID=

# ─── AI / Translation ─────────────────────────────────────
GEMINI_API_KEY=

# ─── TTS / Voice ──────────────────────────────────────────
MURF_API_KEY=

# ─── Proxy (optional, for Edge-TTS) ───────────────────────
EDGE_TTS_PROXY_HOST=
EDGE_TTS_PROXY_PORT=
EDGE_TTS_PROXY_USER=
EDGE_TTS_PROXY_PASS=

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com,https://your-frontend.vercel.app

# ─── Cloudflare R2 Storage ────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=lumixstudio
R2_PUBLIC_URL=

# ─── BullMQ + Redis / Upstash ─────────────────────────────
# Format: redis://default:PASSWORD@HOST:PORT
# Or with TLS: rediss://default:PASSWORD@HOST:PORT
# Get from Upstash Console → Redis → Connect → Node.js
REDIS_URL=
